{
  "name": "uzon",
  "version": "0.5.0",
  "description": "UZON parser and evaluator for TypeScript/JavaScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "uzon-dev",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc && vitest run"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "uzon",
    "config",
    "configuration",
    "parser",
    "data-format",
    "typed",
    "human-readable",
    "serialization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/uzon-dev/uzon-typescript.git"
  },
  "homepage": "https://github.com/uzon-dev/uzon-typescript",
  "bugs": {
    "url": "https://github.com/uzon-dev/uzon-typescript/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
